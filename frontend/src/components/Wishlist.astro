---
import { Image } from 'astro:assets';
import { fetchWishlist, type BoardGame } from "../utils/api";
import GameCard from './GameCard.astro';
import GameDetailsModal from './GameDetailsModal.astro';
import FilterModal from './FilterModal.astro';

const wishlist: BoardGame[] = await fetchWishlist();

function isNewGame(game: BoardGame): boolean {
  if (!game?.createdAt) {
    return false;
  }

  const createdDate = new Date(game.createdAt);
  const oneMonthAgo = new Date();
  oneMonthAgo.setDate(oneMonthAgo.getDate() - 30);
  return createdDate >= oneMonthAgo;
}

function isUpdatedGame(game: BoardGame): boolean {
  if (isNewGame(game) || !game?.lastModified) {
    return false;
  }

  const updatedDate = new Date(game.lastModified);
  const oneMonthAgo = new Date();
  oneMonthAgo.setDate(oneMonthAgo.getDate() - 30);
  return updatedDate >= oneMonthAgo;
}
---
<div class="items-center max-w-sm mx-auto mb-4 flex gap-2">
  <label for="search" class="relative flex-grow">
    <input
      type="text"
      id="search"
      placeholder="Filter by name..."
      autofocus
      class="w-full p-2 rounded border-gray-300 shadow-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white"
    />

    <span id="search-clear" class="absolute inset-y-0 right-2 grid w-8 place-content-center hidden">
          <button
            type="button"
            aria-label="Clear search"
            class="rounded-full p-1.5 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800 cursor-pointer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="size-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18 18 6M6 6l12 12"
              />
            </svg>
          </button>
        </span>
  </label>

  <button
    id="new-filter"
    type="button"
    title="Show only new games"
    aria-label="Show only new games"
    class="px-3 py-2 font-medium rounded bg-white border border-gray-300 text-gray-900 transition-colors dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
    data-active="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         class="size-6">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0M3.124 7.5A8.969 8.969 0 0 1 5.292 3m13.416 0a8.969 8.969 0 0 1 2.168 4.5" />
    </svg>

  </button>

  <button
    id="owned"
    type="button"
    title="Show owned games"
    aria-label="Show owned games"
    class="px-3 py-2 font-medium rounded bg-white border border-gray-300 text-gray-900 transition-colors dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
    data-active="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         class="size-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
    </svg>

  </button>

  <button
    id="open-filters"
    type="button"
    title="Show advanced filters"
    aria-label="Show advanced filters"
    class="px-3 py-2 font-medium rounded bg-white border border-gray-300 text-gray-900 transition-colors dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         class="size-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
    </svg>
  </button>
</div>

<div id="count"
     class="text-center max-w-sm mx-auto mb-4 py-2 px-4 rounded-md bg-gray-50 border border-gray-200 text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-200">
  &nbsp;
</div>

<div id="filter-badges" class="flex flex-wrap gap-2 max-w-sm mx-auto mb-4 hidden">
  <!-- Filter badges dynamically added here -->
</div>

<div class="flex flex-wrap justify-between gap-4">
  {wishlist.sort((a, b) => {
    // Sort order:
    //   if owned: rating
    //   else: price, priority, rating

    if (!a.isOwned && b.isOwned) {
      return -1;
    } else if (a.isOwned && !b.isOwned) {
      return 1;
    }

    if (a.isOwned && b.isOwned) {
      return (b.rating || 0) - (a.rating || 0);
    }

    if (a.price && b.price) {
      if (a.price === b.price) {
        if (a.priority === b.priority) {
          return b.rating - a.rating;
        }
        return a.priority - b.priority;
      }
      return a.price - b.price;
    }
    if (a.price) {
      return -1;
    }
    if (b.price) {
      return 1;
    }
    if (!a.price && !b.price) {
      if (a.priority === b.priority) {
        return b.rating - a.rating;
      }
      return a.priority - b.priority;
    }
    return 1;
  }).map((game) => (
    <GameCard game={game} isNew={isNewGame(game)} isUpdated={isUpdatedGame(game)} />
  ))}
</div>

<div id="no-results" class="max-w-sm mx-auto border-s-4 border-red-700 bg-red-50 p-4 hidden">
  <div class="flex items-center gap-2 text-red-700">
    <Image src="/favicon-32x32.png" alt="d6 dice" width="32" height="32" />
    <strong id="no-results-message" class="font-medium"></strong>
  </div>
</div>

<GameDetailsModal />
<FilterModal />

<!-- Store wishlist data for client-side access -->
<script id="wishlist-data" type="application/json" set:html={JSON.stringify(wishlist)}></script>

<script>
  import '../scripts/wishlist.ts';
</script>
