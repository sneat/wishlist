---
import { Image } from 'astro:assets';
import { fetchWishlist, type BoardGame } from "../utils/api";

const wishlist: BoardGame[] = await fetchWishlist();

function isNewGame(game: BoardGame): boolean {
  if (!game?.createdAt) {
    return false;
  }

  const createdDate = new Date(game.createdAt);
  const oneMonthAgo = new Date();
  oneMonthAgo.setDate(oneMonthAgo.getDate() - 30);
  return createdDate >= oneMonthAgo;
}

function isUpdatedGame(game: BoardGame): boolean {
  if (isNewGame(game) || !game?.lastModified) {
    return false;
  }

  const updatedDate = new Date(game.lastModified);
  const oneMonthAgo = new Date();
  oneMonthAgo.setDate(oneMonthAgo.getDate() - 30);
  return updatedDate >= oneMonthAgo;
}
---
<div class="items-center max-w-sm mx-auto mb-4 flex gap-2">
  <label for="search" class="relative flex-grow">
    <input
      type="text"
      id="search"
      placeholder="Filter by name..."
      autofocus
      class="w-full p-2 rounded border-gray-300 shadow-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white"
    />

    <span class="absolute inset-y-0 right-2 grid w-8 place-content-center">
          <button
            type="button"
            aria-label="Search"
            class="rounded-full p-1.5 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
              />
            </svg>
          </button>
        </span>
  </label>

  <button
    id="new-filter"
    type="button"
    title="Show only new games"
    aria-label="Show only new games"
    class="px-3 py-2 font-medium rounded bg-white border border-gray-300 text-gray-900 transition-colors dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
    data-active="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         class="size-6">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0M3.124 7.5A8.969 8.969 0 0 1 5.292 3m13.416 0a8.969 8.969 0 0 1 2.168 4.5" />
    </svg>

  </button>

  <button
    id="owned"
    type="button"
    title="Show owned games"
    aria-label="Show owned games"
    class="px-3 py-2 font-medium rounded bg-white border border-gray-300 text-gray-900 transition-colors dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
    data-active="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         class="size-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
    </svg>

  </button>
</div>

<div id="count"
     class="text-center max-w-sm mx-auto mb-4 py-2 px-4 rounded-md bg-gray-50 border border-gray-200 text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-200">
  &nbsp;
</div>

<div class="flex flex-wrap justify-between gap-4">
  {wishlist.sort((a, b) => {
    // Sort order:
    //   if owned: rating
    //   else: price, priority, rating

    if (!a.isOwned && b.isOwned) {
      return -1;
    } else if (a.isOwned && !b.isOwned) {
      return 1;
    }

    if (a.isOwned && b.isOwned) {
      return (b.rating || 0) - (a.rating || 0);
    }

    if (a.price && b.price) {
      if (a.price === b.price) {
        if (a.priority === b.priority) {
          return b.rating - a.rating;
        }
        return a.priority - b.priority;
      }
      return a.price - b.price;
    }
    if (a.price) {
      return -1;
    }
    if (b.price) {
      return 1;
    }
    if (!a.price && !b.price) {
      if (a.priority === b.priority) {
        return b.rating - a.rating;
      }
      return a.priority - b.priority;
    }
    return 1;
  }).map((game) => (
    <div
      class="game-card mx-auto max-w-60 rounded-xl shadow-md hover:shadow-xl bg-linear-to-b from-slate-400 to-slate-200 hover:from-slate-200 hover:to-slate-100 active:from-slate-400 active:to-slate-200 p-2 flex flex-col justify-between relative overflow-hidden"
      data-name={game.name.toLowerCase()}
      data-owned={game.isOwned ? "true" : "false"}
      data-players={game.players}
      data-playtime={game.playingTime}
      data-is-new={isNewGame(game)}
      data-is-updated={isUpdatedGame(game)}>
      {isNewGame(game) && (
        <div
          class="absolute top-2 -right-8 w-28 text-center transform rotate-45 bg-red-600 text-white font-bold py-1 shadow-lg">
          NEW
        </div>
      )}
      {isUpdatedGame(game) && (
        <div
          class="absolute top-4 -right-10 w-36 text-center transform rotate-45 bg-red-600 text-white font-bold py-1 shadow-lg">
          UPDATED
        </div>
      )}
      <div>
        <a href={game.bgoUrl}
           target="_blank" rel="noopener noreferrer">
          <Image class="object-contain aspect-square w-32 h-32 rounded-lg mx-auto" src={game.thumbnail}
                 inferSize alt={game.name} />
        </a>
        <div class="mt-1">
          <h2 class="text-lg text-center">
            <a href={game.bgoUrl}
               target="_blank" rel="noopener noreferrer">
              {game.name} ({game.yearPublished})
              {(game.priority > 0 && game.priority < 3) &&
                <span class="*:inline-block *:align-top *:fill-red-500">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                           stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                      </svg>
                    </span>
              }
            </a>
          </h2>
        </div>
      </div>
      <div class="flex flex-row justify-between items-center gap-1">
        {game.price > 0 && !game.isOwned && (
          <a class="px-4 py-2 text-blue-100 bg-cyan-600 rounded hover:bg-cyan-900 hover:underline"
             href={game.bgoUrl} target="_blank"
             rel="noopener noreferrer">
            <span>${game.price}</span>
          </a>
        )}
        {game.isOwned && (
          <span title="I own this game" aria-label="I own this game" class="px-3"></span>
        )}
        {game.rating &&
          <span class="*:inline-block *:align-top">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke-width="1.5" stroke="currentColor" class="size-6">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                </svg>
            {game.rating}
          </span>
        }
        <a class="p-2 rounded bg-indigo-600 hover:bg-indigo-400" href={game.bggUrl} target="_blank"
           rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
               stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
          </svg>
        </a>
      </div>
      {game.isOwned && (
        <div class="text-sm text-gray-600 dark:text-gray-500 flex justify-between gap-1">
          {game.players && (
            <span><strong>Players:</strong> {game.players}</span>
            )}
          {game.playingTime && (
            <span><strong>Playtime:</strong> {game.playingTime}min</span>
          )}
        </div>
      )}
    </div>
  ))}
</div>

<div id="no-results" class="max-w-sm mx-auto border-s-4 border-red-700 bg-red-50 p-4 hidden">
  <div class="flex items-center gap-2 text-red-700">
    <Image src="/favicon-32x32.png" alt="d6 dice" width="32" height="32" />
    <strong id="no-results-message" class="font-medium"></strong>
  </div>
</div>

<script>
  const games = Array.from(document.querySelectorAll(".game-card") as NodeListOf<HTMLElement>);
  const searchInput = document.getElementById("search") as HTMLInputElement | null;
  const gameCountElement = document.getElementById("count");
  const noResultsElement = document.getElementById("no-results");
  const noResultsMessageElement = document.getElementById("no-results-message");
  const newFilterButton = document.getElementById("new-filter");
  const ownedButton = document.getElementById("owned");
  let updateQueryParamsTimeout: number | null = null;

  // Add this after your variable declarations in the script section
  function updateQueryParams() {
    // Clear any pending timeout
    if (updateQueryParamsTimeout !== null) {
      clearTimeout(updateQueryParamsTimeout);
    }

    updateQueryParamsTimeout = window.setTimeout(() => {
      const params = new URLSearchParams(window.location.search);
      const searchTerm = searchInput?.value?.trim() || "";
      const showOnlyNew = newFilterButton?.dataset?.active === "true";
      const showOnlyOwned = ownedButton?.dataset?.active === "true";

      // Update or remove search parameter
      if (searchTerm) {
        params.set("q", searchTerm);
      } else {
        params.delete("q");
      }

      // Update or remove new filter parameter
      if (showOnlyNew) {
        params.set("new", "true");
      } else {
        params.delete("new");
      }

      // Update or remove owned filter parameter
      if (showOnlyOwned) {
        params.set("owned", "true");
      } else {
        params.delete("owned");
      }

      // Update URL without reloading the page
      const newUrl = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
      if (newUrl !== window.location.pathname + window.location.search) {
        window.history.pushState({}, '', newUrl);
      }

      updateQueryParamsTimeout = null;
    }, 500); // Delay to avoid too many updates
  }

  function applyQueryParams() {
    const params = new URLSearchParams(window.location.search);

    // Apply search parameter
    if (searchInput) {
      searchInput.value = params.get("q") || "";
    }

    // Apply new filter parameter
    if (newFilterButton) {
      const onlyNew = params.get("new");
      newFilterButton.dataset.active = onlyNew ? "true" : "false";
      newFilterButton.classList.toggle("invert", onlyNew === "true");
    }

    // Apply owned filter parameter
    if (ownedButton) {
      const onlyOwned = params.get("owned");
      ownedButton.dataset.active = onlyOwned ? "true" : "false";
      ownedButton.classList.toggle("dark:bg-green-300", onlyOwned === "true");
      ownedButton.classList.toggle("dark:border-green-700", onlyOwned === "true");
      ownedButton.classList.toggle("dark:text-green-700", onlyOwned === "true");
      ownedButton.classList.toggle("dark:text-white", !onlyOwned);
    }
  }

  // Function to filter games based on current filters
  function filterGames() {
    const searchTerm = searchInput?.value?.toLowerCase().trim() || "";
    const showOnlyNew = newFilterButton?.dataset?.active === "true";
    const showOnlyOwned = ownedButton?.dataset?.active === "true";

    games.forEach(game => {
      const gameName = game.dataset.name || "";
      const isNew = game.dataset.isNew === "true";
      const isUpdated = game.dataset.isUpdated === "true";
      const isOwned = game.dataset.owned === "true";

      const matchesSearch = gameName.includes(searchTerm);
      const matchesNewFilter = !showOnlyNew || (showOnlyNew && (isNew || isUpdated));
      const matchesOwnedFilter = (!showOnlyOwned && !isOwned) || (showOnlyOwned && isOwned);

      if (matchesSearch && matchesNewFilter && matchesOwnedFilter) {
        game.style.display = "";
      } else {
        game.style.display = "none";
      }
    });

    // Update "no results" message
    if (noResultsMessageElement) {
      let message = "I'm not tracking any board games.";

      if (showOnlyNew && showOnlyOwned) {
        message = searchTerm
          ? `No games matching "${searchTerm}" that I own have been added in the last month.`
          : "No games that I own have been added in the last month.";
      } else if (showOnlyNew) {
        message = searchTerm
          ? `No games matching "${searchTerm}" have been added in the last month.`
          : "No games have been added in the last month.";
      } else if (showOnlyOwned) {
        message = searchTerm
          ? `I don't own any games matching "${searchTerm}".`
          : "I don't own any board games yet 😭";
      } else if (searchTerm) {
        message = `No games matching "${searchTerm}" are on my wishlist.`;
      }

      noResultsMessageElement.textContent = message;
    }

    const visibleGames = games.filter(game => game.style.display !== "none");
    noResultsElement?.classList.toggle("hidden", visibleGames.length > 0);

    if (gameCountElement) {
      gameCountElement.textContent = `Showing ${visibleGames.length}`;
      if (showOnlyNew) {
        gameCountElement.textContent += " recently added";
      }
      gameCountElement.textContent += ` game${visibleGames.length !== 1 ? "s" : ""}`;
      if (showOnlyOwned) {
        gameCountElement.textContent += " that I own";
      }
      gameCountElement.textContent += ".";
    }
  }

  // Search input event listener
  searchInput?.addEventListener("input", () => {
    filterGames();
    updateQueryParams();
  });

  // New filter button event listener
  newFilterButton?.addEventListener("click", () => {
    const currentlyActive = newFilterButton.dataset.active === "true";
    newFilterButton.dataset.active = (!currentlyActive).toString();
    newFilterButton.classList.toggle("invert");

    updateQueryParams();
    filterGames();
  });

  // Owned filter button event listener
  ownedButton?.addEventListener("click", () => {
    const currentlyActive = ownedButton.dataset.active === "true";
    ownedButton.dataset.active = (!currentlyActive).toString();
    ownedButton.classList.toggle("dark:bg-green-300");
    ownedButton.classList.toggle("dark:border-green-700");
    ownedButton.classList.toggle("dark:text-green-700");
    ownedButton.classList.toggle("dark:text-white");

    updateQueryParams();
    filterGames();
  });

  window.addEventListener("popstate", (event) => {
    console.log("Popstate event triggered", event, "Current URL:", window.location.href);
    // Reapply query params and filter games when navigating back/forward
    applyQueryParams();
    filterGames();
  });

  // Initial filter application
  applyQueryParams();
  filterGames();
</script>