---
import { Image } from 'astro:assets';
import type { BoardGame } from "../utils/api";

interface Props {
  game: BoardGame;
  isNew: boolean;
  isUpdated: boolean;
}

const { game, isNew, isUpdated } = Astro.props;
---

<div
  class="game-card mx-auto max-w-60 rounded-xl shadow-md hover:shadow-xl bg-linear-to-b from-slate-400 to-slate-200 hover:from-slate-200 hover:to-slate-100 active:from-slate-400 active:to-slate-200 p-2 flex flex-col justify-between relative overflow-hidden"
  data-name={game.name.toLowerCase()}
  data-owned={game.isOwned ? "true" : "false"}
  data-players={game.players}
  data-playtime={game.playingTime}
  data-priority={game.priority}
  data-price={game.price}
  data-is-new={isNew}
  data-is-updated={isUpdated}>
  {isNew && (
    <div
      class="absolute top-2 -right-8 w-28 text-center transform rotate-45 bg-red-600 text-white font-bold py-1 shadow-lg">
      NEW
    </div>
  )}
  {isUpdated && (
    <div
      class="absolute top-4 -right-10 w-36 text-center transform rotate-45 bg-red-600 text-white font-bold py-1 shadow-lg">
      UPDATED
    </div>
  )}
  <div>
    <Image class="object-contain aspect-square w-32 h-32 rounded-lg mx-auto" src={game.thumbnail}
           inferSize alt={game.name} />
    <div class="mt-1">
      <h2 class="text-lg text-center">
        {game.name}{game.yearPublished > 0 ? ` (${game.yearPublished})` : ""}
        {(game.priority > 0 && game.priority < 3) &&
          <span class="*:inline-block *:align-top *:fill-red-500">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </span>
        }
      </h2>
    </div>
  </div>
  <div class="flex flex-row justify-between items-center gap-1">
    {game.price > 0 && !game.isOwned && (
      <span class="px-4 py-2 text-blue-100 bg-cyan-600 rounded">
        ${game.price}
      </span>
    )}
    {game.isOwned && (
      <span title="I own this game" aria-label="I own this game" class="px-3"></span>
    )}
    {game.rating &&
      <span class="*:inline-block *:align-top">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
        </svg>
        {game.rating}
      </span>
    }
  </div>
  {game.isOwned && (
    <div class="text-sm text-gray-600 dark:text-gray-500 flex justify-between gap-1">
      {game.players && (
        <span><strong>Players:</strong> {game.players}</span>
        )}
      {game.playingTime && (
        <span><strong>Playtime:</strong> {game.playingTime}min</span>
      )}
    </div>
  )}
</div>
