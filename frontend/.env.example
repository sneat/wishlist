# Set the environment (development or production)
ENV=development

# Backend public API endpoint
PUBLIC_API_URL=http://127.0.0.1:8090

# Public site URL (used for sitemap, canonical URLs, etc.)
PUBLIC_SITE_URL=http://localhost:4321

# Board Game Oracle locale used in outbound BGO links (language-region)
PUBLIC_BGO_LOCALE=en-AU
